<div class="flexcol" style="gap: 0.375rem;">
  {{#if allowSelect}}
    <div class="flexrow">
      <select name="existing-skill">
        <option value="">{{localize 'CoC7.SkillPickNameOnly'}}</option>
        {{selectOptions skills selected=selected valueAttr='id' labelAttr='name'}}
      </select>
    </div>
  {{/if}}
  {{#if (and allowCustom (eq selected ''))}}
    <div>
      <div class="form-group">
        <label>{{localize 'CoC7.CustomSpecialisationLabel' specialisation=label}}</label>
      </div>
      <div class="form-group">
        <input name="new-skill-name" type="text" value="{{name}}" placeholder="{{localize 'CoC7.CreateNewSkill'}}" />
      </div>
    </div>

    {{#unless fixedBaseValue}}
      <div class="form-group">
        <label>{{localize 'CoC7.BaseSkillValue'}}</label>
        <div class="form-fields">
          <input name="base-value" type="text" value="{{baseValue}}" placeholder="{{localize 'CoC7.SkillBase'}}" />
        </div>
      </div>
    {{/unless}}
  {{/if}}
</div>