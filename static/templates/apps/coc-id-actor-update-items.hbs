<div class="flexcol" style="gap: 0.375rem;">
  <p style="background-color: rgba(255, 166, 0, 0.5); outline: 2px dashed rgba(255, 100, 0, 0.3); padding: 0.5rem;"><i class="fa-solid fa-exclamation-triangle"></i> {{localize 'CoC7.ActorCoCIDItemsWarning'}}</p>
  <p>{{localize 'CoC7.ActorCoCIDItemsWhich'}}</p>
  <ul style="margin: 0;">
    <li>{{localize 'CoC7.ActorCoCIDItemsRules1' era=era}}</li>
    {{#unless isEn}}
      <li>{{localize 'CoC7.ActorCoCIDItemsRules2' lang=lang}}</li>
    {{/unless}}
    <li>{{localize 'CoC7.ActorCoCIDItemsRules3'}}</li>
  </ul>
  <div class="form-group toggle-row">
    <div class="toggle-attributes flexcol" style="justify-content: center; gap: 0.5rem">
      <div><button class="toggle-switch toggle-switch-larger{{#if coc7Config.unlinked}} switched-on{{/if}}" data-property="unlinked">{{localize 'CoC7.ActorCoCIDItemsUnlinkedToken'}}</button></div>
      <div><button class="toggle-switch toggle-switch-larger{{#if coc7Config.anySkills}} switched-on{{/if}}" data-property="anySkills">{{localize 'CoC7.ActorCoCIDItemsAny'}}</button></div>
    </div>
  </div>
  <div style="flex: 0 0 1rem"></div>
  <div class="form-group toggle-row flexrow">
    <div class="toggle-attributes flexrow" style="justify-content: center">
      <button class="toggle-switch toggle-switch-larger{{#if (eq coc7Config.which Which.SceneTokens)}} switched-on{{/if}}" data-property="which" data-value="{{Which.SceneTokens}}">{{localize 'CoC7.ActorCoCIDItemsSceneTokens'}}</button>
      <button class="toggle-switch toggle-switch-larger{{#if (eq coc7Config.which Which.ActorSheets)}} switched-on{{/if}}" data-property="which" data-value="{{Which.ActorSheets}}">{{localize 'CoC7.ActorCoCIDItemsActorSheets'}}</button>
      <button class="toggle-switch toggle-switch-larger{{#if (eq coc7Config.which Which.ActorDirectory)}} switched-on{{/if}}" data-property="which" data-value="{{Which.ActorDirectory}}">{{localize 'CoC7.ActorCoCIDItemsActorDirectory'}}</button>
    </div>
  </div>
</div>