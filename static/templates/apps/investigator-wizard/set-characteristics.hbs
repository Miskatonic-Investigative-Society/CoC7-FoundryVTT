<div class="panel flexcol">
  <h1>{{localize 'CoC7.InvestigatorWizard.TitleCharacteristics'}}</h1>
  <div class="scroll-section">
    {{#if (gt coreCharacteristics.length 1)}}
      <div class="form-group">
        <label for="coc-core-characteristic">{{localize 'CoC7.InvestigatorWizard.CoreCharacteristicSelect'}}:</label>
        <select name="coc-core-characteristic">
          <option value="">&nbsp;</option>
          {{selectOptions coreCharacteristics selected=coc7Config.coreCharacteristic valueAttr='key' labelAttr='name'}}
        </select>
      </div>
      <div class="form-group">
        &nbsp;
      </div>
    {{/if}}
    {{#if (or coc7Config.coreCharacteristic (lt coreCharacteristics.length 1))}}
      {{#if (or (eq characteristicsMethod characteristicsMethods.METHOD_VALUES) (eq characteristicsMethod characteristicsMethods.METHOD_CHOOSE))}}
        <p>{{localize 'CoC7.InvestigatorWizard.CharacteristicDragInformation'}}</p>
        {{#if coc7Config.coreCharacteristic}}
          <p>{{{localize 'CoC7.InvestigatorWizard.CoreCharacteristicName' coreCharacteristic=coreCharacteristic}}}</p>
        {{/if}}
        <div class="place-characteristics flexcol">
          {{#if (eq characteristicsMethod characteristicsMethods.METHOD_CHOOSE)}}
            {{#if (or coc7Config.rerollsEnabled (not coc7Config.rolledValues.length))}}
              <div class="flexrow">
                <div class="flex2"></div>
                <button class="roll_choose">{{localize 'CoC7.RollDice'}}</button>
                <div class="flex2"></div>
              </div>
            {{/if}}
            {{#if coc7Config.rolledValues.length}}
              <div class="drop-location flexrow" data-empty="x">
                {{#each coc7Config.rolledValues as |roll offset|}}
                  {{#unless roll.assigned}}
                    <div draggable="true" class="draggable characteristic" data-offset="{{offset}}">
                      <div>{{roll.value}}</div>
                    </div>
                  {{/unless}}
                {{/each}}
              </div>
            {{/if}}
          {{else}}
            <div class="drop-location flexrow" data-characteristic-key="-">
              {{#each coc7Config.placeable as |value|}}
                <div draggable="true" class="draggable characteristic" data-characteristic-key="-" data-value="{{value}}">
                  <div>{{value}}</div>
                </div>
              {{/each}}
            </div>
          {{/if}}
          {{#each setup.characteristics as |characteristic|}}
            <div class="drop-location flexrow" data-characteristic-key="{{characteristic.key}}">
              <label class="flex2">{{localize characteristic.label}}:</label>
              <div class="item-controls"></div>
              <input type="number" {{#if (ne (lookup ../coc7Config.setupPoints characteristic.key) '' )}} draggable="true" {{/if}} class="{{#if (eq (lookup ../coc7Config.setupPoints characteristic.key) '')}}not-draggable{{else}}draggable{{/if}}" data-characteristic-key="{{characteristic.key}}" value="{{lookup ../coc7Config.setupPoints characteristic.key}}" readonly />
              <div class="item-controls"></div>
            </div>
          {{/each}}
          <div class="input-line flexrow" data-key="luck" data-formula="{{setup.luck.roll}}">
            <label class="flex2">{{localize setup.luck.label}} - {{setup.luck.roll}}:</label>
            <div class="item-controls"></div>
            <input type="number" class="not-draggable save-on-blur" value="{{lookup coc7Config.setupPoints 'luck'}}" placeholder="{{localize 'CoC7.Value'}}"{{#if (and (not coc7Config.rerollsEnabled) (lookup coc7Config.setupPoints 'luck'))}} readonly{{/if}} />
            <div class="item-controls">
              {{#if (or coc7Config.rerollsEnabled (eq (lookup coc7Config.setupPoints 'luck') ''))}}
                <a class="item-control" data-action="roll-characteristic"><i class="fa-solid fa-dice"></i></a>
              {{/if}}
            </div>
          </div>
          <div class="input-line flexrow" data-key="age">
            <label for="age" class="flex2">{{localize 'CoC7.InvestigatorWizard.AgeRange'}}</label>
            <div class="item-controls"></div>
            <input type="number" class="not-draggable save-on-blur" value="{{coc7Config.age}}" />
            <div class="item-controls"></div>
          </div>
        </div>
      {{else}}
        <div class="place-characteristics flexcol">
          {{#each setup.characteristics as |characteristic|}}
            <div class="input-line flexrow" data-key="{{characteristic.key}}" data-formula="{{characteristic.roll}}" data-min="0" data-max="">
              <label class="flex2">{{localize characteristic.label}}{{#if (eq ../characteristicsMethod ../characteristicsMethods.METHOD_ROLL)}} - {{characteristic.roll}}{{/if}}:</label>
              <div class="item-controls">
                {{#if (eq ../characteristicsMethod ../characteristicsMethods.METHOD_POINTS)}}
                  <a class="item-control" data-action="modify-characteristic" data-by="-10"><i class="fa-solid fa-angles-down"></i></a>
                  <a class="item-control" data-action="modify-characteristic" data-by="-1"><i class="fa-regular fa-minus-circle"></i></a>
                {{/if}}
              </div>
              <input type="number" class="not-draggable save-on-blur" {{#if (ne ../characteristicsMethod ../characteristicsMethods.METHOD_POINTS)}} readonly="readonly" {{/if}} value="{{lookup ../coc7Config.setupPoints characteristic.key}}" placeholder="{{localize 'CoC7.Value'}}" />
              <div class="item-controls">
                {{#if (eq ../characteristicsMethod ../characteristicsMethods.METHOD_ROLL)}}
                  {{#if (or ../coc7Config.rerollsEnabled (eq (lookup ../coc7Config.setupPoints characteristic.key) ''))}}
                    <a class="item-control" data-action="roll-characteristic"><i class="fa-solid fa-dice"></i></a>
                  {{/if}}
                {{else}}
                  <a class="item-control" data-action="modify-characteristic" data-by="1"><i class="fa-regular fa-plus-circle"></i></a>
                  <a class="item-control" data-action="modify-characteristic" data-by="10"><i class="fa-solid fa-angles-up"></i></a>
                {{/if}}
              </div>
            </div>
          {{/each}}
          <div class="input-line flexrow" data-key="luck" data-formula="{{setup.luck.roll}}">
            <label class="flex2">{{localize setup.luck.label}} - {{setup.luck.roll}}:</label>
            <div class="item-controls"></div>
            <input type="number" class="not-draggable save-on-blur" value="{{lookup coc7Config.setupPoints 'luck'}}" placeholder="{{localize 'CoC7.Value'}}"{{#if (and (not coc7Config.rerollsEnabled) (lookup coc7Config.setupPoints 'luck'))}} readonly{{/if}} />
            <div class="item-controls">
              {{#if (or coc7Config.rerollsEnabled (eq (lookup coc7Config.setupPoints 'luck') ''))}}
                <a class="item-control" data-action="roll-characteristic"><i class="fa-solid fa-dice"></i></a>
              {{/if}}
            </div>
          </div>
          <div></div>
          {{#if (eq characteristicsMethod characteristicsMethods.METHOD_POINTS)}}
            <div class="flexrow">
              <label class="flex2">{{localize 'CoC7.CharacteristicsPoints'}}:</label>
              <div class="item-controls"></div>
              <div class="not-draggable">
                <span class='total'>{{setup.total}}</span>
                <span class='sep'>/</span>
                <span class='value'>{{setup.points}}</span>
              </div>
              <div class="item-controls"></div>
            </div>
          {{else}}
            <div class="flexrow">
              <label class="flex2">{{localize 'CoC7.CharacteristicsPoints'}}:</label>
              <div class="item-controls"></div>
              <div class="not-draggable">
                {{setup.total}}
              </div>
              <div class="item-controls"></div>
            </div>
            <div></div>
            <div class="flexrow">
              <div class="flex2"></div>
              <button class="roll_choose">{{localize 'CoC7.RollDice'}}</button>
              <div class="flex2"></div>
            </div>
          {{/if}}
          <div></div>
          <div class="input-line flexrow" data-key="age">
            <label for="age" class="flex2">{{localize 'CoC7.InvestigatorWizard.AgeRange'}}</label>
            <div class="item-controls"></div>
            <input type="number" class="not-draggable save-on-blur" value="{{coc7Config.age}}" />
            <div class="item-controls"></div>
          </div>
        </div>
      {{/if}}
    {{/if}}
  </div>
</div>