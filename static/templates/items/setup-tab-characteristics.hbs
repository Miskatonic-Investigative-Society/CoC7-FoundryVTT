<section class="tab characteristics flexcol scrollable {{tab.cssClass}}" data-group="primary" data-tab="characteristics">
  {{#if tabs.characteristics}}
    <fieldset class="flexcol">
      <div class="form-group toggle-row flexrow">
        <label>{{localize 'CoC7.UsePoints'}}</label>
        <div class="toggle-attributes flexrow" data-set="characteristics.points" style="justify-content: center;">
          <button class="toggle-switch{{#if document.system.characteristics.points.enabled}} switched-on{{/if}}" data-property="enabled" type="button">{{localize 'CoC7.UsePoints'}}</button>
        </div>
      </div>
      <div class="form-group flexrow">
        <label>{{localize 'CoC7.CharacteristicsPoints'}}</label>
        <input type="text" name="system.characteristics.points.value" value="{{document.system.characteristics.points.value}}" placeholder="{{localize 'CoC7.Value'}}" />
      </div>
    </fieldset>
    <fieldset class="flexcol">
      <div class="form-group toggle-row flexrow">
        <label>{{localize 'CoC7.UseRolls'}}</label>
        <div class="toggle-attributes flexrow" data-set="characteristics.rolls" style="justify-content: center;">
          <button class="toggle-switch{{#if document.system.characteristics.rolls.enabled}} switched-on{{/if}}" data-property="enabled" type="button">{{localize 'CoC7.UseRolls'}}</button>
        </div>
      </div>
      <div class="form-group flexrow">
        <label>{{localize 'CHARAC.Strength'}}</label>
        <input type="text" name="system.characteristics.rolls.str" value="{{document.system.characteristics.rolls.str}}" placeholder="{{localize 'CoC7.EnterFormula'}}" />
      </div>
      <div class="form-group flexrow">
        <label>{{localize 'CHARAC.Constitution'}}</label>
        <input type="text" name="system.characteristics.rolls.con" value="{{document.system.characteristics.rolls.con}}" placeholder="{{localize 'CoC7.EnterFormula'}}" />
      </div>
      <div class="form-group flexrow">
        <label>{{localize 'CHARAC.Size'}}</label>
        <input type="text" name="system.characteristics.rolls.siz" value="{{document.system.characteristics.rolls.siz}}" placeholder="{{localize 'CoC7.EnterFormula'}}" />
      </div>
      <div class="form-group flexrow">
        <label>{{localize 'CHARAC.Dexterity'}}</label>
        <input type="text" name="system.characteristics.rolls.dex" value="{{document.system.characteristics.rolls.dex}}" placeholder="{{localize 'CoC7.EnterFormula'}}" />
      </div>
      <div class="form-group flexrow">
        <label>{{localize 'CHARAC.Appearance'}}</label>
        <input type="text" name="system.characteristics.rolls.app" value="{{document.system.characteristics.rolls.app}}" placeholder="{{localize 'CoC7.EnterFormula'}}" />
      </div>
      <div class="form-group flexrow">
        <label>{{localize 'CHARAC.Intelligence'}}</label>
        <input type="text" name="system.characteristics.rolls.int" value="{{document.system.characteristics.rolls.int}}" placeholder="{{localize 'CoC7.EnterFormula'}}" />
      </div>
      <div class="form-group flexrow">
        <label>{{localize 'CHARAC.Power'}}</label>
        <input type="text" name="system.characteristics.rolls.pow" value="{{document.system.characteristics.rolls.pow}}" placeholder="{{localize 'CoC7.EnterFormula'}}" />
      </div>
      <div class="form-group flexrow">
        <label>{{localize 'CHARAC.Education'}}</label>
        <input type="text" name="system.characteristics.rolls.edu" value="{{document.system.characteristics.rolls.edu}}" placeholder="{{localize 'CoC7.EnterFormula'}}" />
      </div>
      <div class="form-group flexrow">
        <label>{{localize 'CoC7.Luck'}}</label>
        <input type="text" name="system.characteristics.rolls.luck" value="{{document.system.characteristics.rolls.luck}}" placeholder="{{localize 'CoC7.EnterFormula'}}" />
      </div>
    </fieldset>
  {{/if}}
</section>