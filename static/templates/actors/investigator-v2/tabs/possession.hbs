<section class="tab possession scrollable {{tabs.possession.cssClass}}" data-group="primary" data-tab="possession">
  <div class="inventory">
    <div class="gear">
      {{#unless hasInventory}}
        <h3 class="warning">{{localize 'CoC7.InventoryIsCurrentlyEmpty'}}</h3>
      {{else}}
        {{#if showInventoryItems}}
          <section class="items">
            <header class="section-header">
              <h3 class="section-heading">{{localize 'CoC7.Items'}}</h3>
              {{#unless document.system.flags.locked}}
                <div class="item-controls">
                  <a class="item-control" data-action="item-add" data-type="item" data-tooltip="CoC7.AddItem"><i class="fa-regular fa-plus-circle"></i></a>
                </div>
              {{/unless}}
            </header>
            <ul class="item-list">
              {{#each itemsByType.item as |item|}}
                <li class="item flexrow draggable" data-item-uuid="{{item.uuid}}">
                  <div class="item-image" style="background-image: url({{item.img}})"></div>
                  <div class="item-name show-detail">{{system.quantity}} x {{item.name}}</div>
                  <div class="item-controls">
                    <a class="item-control" data-action="item-trade" data-tooltip="CoC7.TradeItem"><i class="game-icon game-icon-trade"></i></a>
                    <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditItem"><i class="fa-solid fa-edit"></i></a>
                    <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteItem"><i class="fa-solid fa-trash"></i></a>
                  </div>
                </li>
              {{/each}}
            </ul>
          </section>
        {{/if}}
        {{#if showInventoryBooks}}
          <section class="items">
            <header class="section-header">
              <h3 class="section-heading">{{localize 'CoC7.Books'}}</h3>
              {{#unless document.system.flags.locked}}
                <div class="item-controls">
                  <a class="item-control" data-action="item-add" data-type="book" data-tooltip="CoC7.AddBook"><i class="fa-regular fa-plus-circle"></i></a>
                </div>
              {{/unless}}
            </header>
            <ul class="item-list">
              {{#each itemsByType.book as |item|}}
                <li class="item flexrow draggable" data-item-uuid="{{item.uuid}}">
                  <div class="item-image" style="background-image: url({{item.img}})"></div>
                  <div class="item-name show-detail">{{item.name}}</div>
                  <div class="item-controls">
                    <a class="item-control" data-action="item-trade" data-tooltip="CoC7.TradeItem"><i class="game-icon game-icon-trade"></i></a>
                    <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditItem"><i class="fa-solid fa-edit"></i></a>
                    <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteItem"><i class="fa-solid fa-trash"></i></a>
                  </div>
                </li>
              {{/each}}
            </ul>
          </section>
        {{/if}}
        {{#if showInventorySpells}}
          <section class="items">
            <header class="section-header">
              <h3 class="section-heading">{{localize 'CoC7.Spells'}}</h3>
              {{#unless document.system.flags.locked}}
                <div class="item-controls">
                  <a class="item-control" data-action="item-add" data-type="spell" data-tooltip="CoC7.AddSpell"><i class="fa-regular fa-plus-circle"></i></a>
                </div>
              {{/unless}}
            </header>
            <ul class="item-list">
              {{#each itemsByType.spell as |item|}}
                <li class="item flexrow" data-item-uuid="{{item.uuid}}">
                  <div class="item-image" style="background-image: url({{item.img}})"></div>
                  <div class="item-name show-detail">{{item.name}}</div>
                  <div class="item-controls">
                    <a class="item-control" data-action="item-trade" data-tooltip="CoC7.TradeItem"><i class="game-icon game-icon-trade"></i></a>
                    <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditItem"><i class="fa-solid fa-edit"></i></a>
                    <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteItem"><i class="fa-solid fa-trash"></i></a>
                  </div>
                </li>
              {{/each}}
            </ul>
          </section>
        {{/if}}
        {{#if showInventoryTalents}}
          <section class="items">
            <header class="section-header">
              <h3 class="section-heading">{{localize 'CoC7.PulpTalents'}}</h3>
            </header>
            <ul class="item-list">
              {{#each itemsByType.talent as |item|}}
                <li class="item flexrow" data-item-uuid="{{item.uuid}}">
                  <div class="item-image" style="background-image: url({{item.img}})"></div>
                  <div class="item-name show-detail">{{item.name}}</div>
                  <div class="item-controls">
                    <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditItem"><i class="fa-solid fa-edit"></i></a>
                    <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteItem"><i class="fa-solid fa-trash"></i></a>
                  </div>
                </li>
              {{/each}}
            </ul>
          </section>
        {{/if}}
        {{#if showInventoryWeapons}}
          <section class="items">
            <header class="section-header">
              <h3 class="section-heading">{{localize 'CoC7.Weapons'}}</h3>
              {{#unless document.system.flags.locked}}
                <div class="item-controls">
                  <a class="item-control" data-action="item-add" data-type="weapon" data-tooltip="CoC7.AddWeapon"><i class="fa-regular fa-plus-circle"></i></a>
                </div>
              {{/unless}}
            </header>
            <ul class="item-list">
              {{#each itemsByType.weapon as |item|}}
                <li class="item flexrow draggable" data-item-uuid="{{item.uuid}}">
                  <div class="item-image" style="background-image: url({{item.img}})"></div>
                  <div class="item-name show-detail">{{item.name}}</div>
                  <div class="item-controls">
                    <a class="item-control" data-action="item-trade" data-tooltip="CoC7.TradeItem"><i class="game-icon game-icon-trade"></i></a>
                    <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditItem"><i class="fa-solid fa-edit"></i></a>
                    <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteItem"><i class="fa-solid fa-trash"></i></a>
                  </div>
                </li>
              {{/each}}
            </ul>
          </section>
        {{/if}}
        {{#if showInventoryArmor}}
          <section class="items">
            <header class="section-header">
              <h3 class="section-heading">{{localize 'CoC7.Armor'}}</h3>
              {{#unless document.system.flags.locked}}
                <div class="item-controls">
                  <a class="item-control" data-action="item-add" data-type="armor" data-tooltip="CoC7.AddArmor"><i class="fa-regular fa-plus-circle"></i></a>
                </div>
              {{/unless}}
            </header>
            <ul class="item-list">
              {{#each itemsByType.armor as |item|}}
                <li class="item flexrow draggable" data-item-uuid="{{item.uuid}}">
                  <div class="item-image" style="background-image: url({{item.img}})"></div>
                  <div class="item-name show-detail">{{item.name}}</div>
                  <div class="item-controls">
                    <a class="item-control" data-action="item-trade" data-tooltip="CoC7.TradeItem"><i class="game-icon game-icon-trade"></i></a>
                    <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditItem"><i class="fa-solid fa-edit"></i></a>
                    <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteItem"><i class="fa-solid fa-trash"></i></a>
                  </div>
                </li>
              {{/each}}
            </ul>
          </section>
        {{/if}}
        {{#if showInventoryStatuses}}
          <section class="items">
            <header class="section-header">
              <h3 class="section-heading">{{localize 'CoC7.Status'}}</h3>
            </header>
            <ul class="item-list">
              {{#each itemsByType.status as |item|}}
                <li class="item flexrow" data-item-uuid="{{item.uuid}}">
                  <div class="item-image" style="background-image: url({{item.img}})"></div>
                  <div class="item-name show-detail">{{item.name}}</div>
                  <div class="item-controls">
                    {{#if ../isKeeper}}
                      <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditItem"><i class="fa-solid fa-edit"></i></a>
                      <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteItem"><i class="fa-solid fa-trash"></i></a>
                    {{/if}}
                  </div>
                </li>
              {{/each}}
            </ul>
          </section>
        {{/if}}
      {{/unless}}
    </div>
    <div class="cash">
      {{#unless document.system.flags.locked}}
        <div class="cash-row">
          {{#if document.system.flags.manualCredit}}
            <label>{{localize 'CoC7.ManualCreditValues'}}</label>
            <div class="flex1"></div>
          {{/if}}
          <div class="{{#if document.system.flags.manualCredit}}auto-off{{else}}auto-on{{/if}} item-control" data-action="toggle-flag" data-toggle-flag="manualCredit" data-tooltip="CoC7.AutoCreditValues">
            <i class="fa-solid fa-cogs"></i>
          </div>
        </div>
      {{/unless}}
      <div class="cash-row">
        <label>{{localize 'CoC7.MonetarySpendingLevel'}}</label>
        {{#if document.system.flags.manualCredit}}
          <input type="text" name="system.monetary.spendingLevel" value="{{document.system.monetary.spendingLevel}}">
        {{else}}
          <span>{{monetary.spendingLevel}}</span>
        {{/if}}
      </div>
      <div class="cash-row">
        <label>{{localize 'CoC7.MonetaryCash'}}</label>
        {{#if document.system.flags.manualCredit}}
          <input type="text" name="system.monetary.cash" value="{{document.system.monetary.cash}}">
        {{else}}
          <span>{{monetary.cash}}</span>
        {{/if}}
      </div>
      <div class="cash-row">
        <label>{{localize 'CoC7.MonetarySpent'}}</label><input type="text" name="system.monetary.spent" value="{{document.system.monetary.spent}}">
      </div>
      <div class="cash-row">
        <label>{{localize 'CoC7.MonetaryAssets'}}</label>
        {{#if document.system.flags.manualCredit}}
          <input type="text" name="system.monetary.assets" value="{{document.system.monetary.assets}}">
        {{else}}
          <span>{{monetary.assets}}</span>
        {{/if}}
      </div>
      <div>
        <textarea name="system.monetary.assetsDetails" placeholder="{{localize 'CoC7.MonetaryAssetsDetails'}}" rows="4">{{document.system.monetary.assetsDetails}}</textarea>
      </div>
      <label>{{localize 'CoC7.PossessionsNotes'}}</label>
      <div>
        <textarea name="system.notes" placeholder="{{localize 'CoC7.PossessionsNotesHolder'}}">{{document.system.notes}}</textarea>
      </div>
    </div>
  </div>
</section>