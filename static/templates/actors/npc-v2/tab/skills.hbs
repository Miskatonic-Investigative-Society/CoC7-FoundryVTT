<div class="skill-list flexrow">
  {{#each itemsByType.skill as |skill|}}
    <div class="item skill flexrow" data-item-uuid="{{skill.uuid}}">
      {{#if skill.system.properties.special}}
        <div class="npc-specialization">{{skill.system.specialization}}</div>
      {{/if}}
      {{#if ../document.system.flags.locked}}
        <div class="skill-name rollable" data-name-tooltip="{{skill.name}}" data-value-tooltip="{{skill.system.value}}">{{skill.system.skillName}}</div>
        <input class="detail-value{{#unless skill.system.activeEffectValue}} npc-skill-score read-only{{/unless}}" type="text" value="{{skill.system.value}}" readonly>
        <span class="pc">%</span>
      {{else}}
        <input class="skill-name" type="text" value="{{skill.system.skillName}}">
        <input class="detail-value npc-skill-score" type="text" value="{{skill.system.valueUnmodified}}">
        <div class="item-controls">
          <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditSkill"><i class="fa-solid fa-edit"></i></a>
          <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteSkill"><i class="fa-solid fa-trash"></i></a>
        </div>
      {{/if}}
    </div>
  {{/each}}
</div>