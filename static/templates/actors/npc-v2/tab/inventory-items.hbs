<div class="inventory-tab">
  {{#if showInventoryItems}}
    <div class="tab-group flexcol" data-panel="InventoryItems" {{#if document.system.flags.panelInventoryItems}} data-html-element-toggled="on" {{/if}}>
      <div class="tab-group-header">
        {{#unless document.system.flags.locked}}
          <div class="item-controls">
          </div>
        {{/unless}}
        <div class="tab-group-title">{{localize 'CoC7.Items'}}</div>
        {{#unless document.system.flags.locked}}
          <div class="item-controls">
            <a class="item-control" data-action="item-add" data-tooltip="CoC7.AddItem" data-type="item"><i class="fa-regular fa-plus-circle"></i></a>
          </div>
        {{/unless}}
      </div>
      <div class="tab-group-tab html-element-toggled{{#unless document.system.flags.panelInventoryItems}} html-element-hidden{{/unless}}">
        <div class="item-list flexcol">
          {{#each itemsByType.item as |item|}}
            <div class="item flexrow" data-item-uuid="{{item.uuid}}">
              <div class="item-image" style="background-image: url({{item.img}})"></div>
              <div class="item-name show-detail">{{#unless (eq system.quantity 1)}}{{system.quantity}} x {{/unless}}{{item.name}}</div>
              <div class="item-controls">
                <a class="item-control" data-action="item-trade" data-tooltip="CoC7.TradeItem"><i class="game-icon game-icon-trade"></i></a>
                <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditItem"><i class="fa-solid fa-edit"></i></a>
                <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteItem"><i class="fa-solid fa-trash"></i></a>
              </div>
            </div>
          {{/each}}
        </div>
      </div>
    </div>
  {{/if}}
  {{#if showInventoryBooks}}
