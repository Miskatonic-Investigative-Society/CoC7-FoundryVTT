<section class="tab keeper flexcol scrollable {{tabs.keeper.cssClass}}" data-group="primary" data-tab="keeper">
  {{#if tabs.keeper}}
    <header class="tab-header">
      {{#if hasConditions}}
        <div class="item-controls"><a class="clear_conditions button"><i class="fa-solid fa-trash"></i>{{localize 'CoC7.ClearAllConditions'}}</a></div>
      {{/if}}
      <h2 class="tab-heading">{{localize 'CoC7.GmNotes'}}</h2>
    </header>
    <section class="bio-section">
      <prose-mirror name="system.description.keeper" value="{{document.system.description.keeper}}" data-document-uuid="{{document.uuid}}" toggled>{{{enrichedDescriptionKeeper}}}</prose-mirror>
    </section>
    <div class="boxes">
      <section class="bio-section">
        <header class="section-header">
          <h3 class="section-heading">{{localize 'CoC7.SanityLossEncounters'}}</h3>
          <div class="item-controls">
            <a class="item-control" data-action="sanity-loss-type-add" data-type="encounter" data-tooltip="CoC7.AddSanityLossEncounter"><i class="fa-regular fa-plus-circle"></i></a>
          </div>
        </header>
        <div class="events">
          {{#each document.system.sanityLossEvents as |sanityLossEvent index|}}
            {{#unless sanityLossEvent.immunity}}
              <div class="event" data-index="{{index}}">
                <div class="title">{{sanityLossEvent.type}}</div>
                <div class="values">
                  <input name="system.sanityLossEvents.{{index}}.totalLoss" type="text" value="{{sanityLossEvent.totalLoss}}">
                </div>
                <div class="item-controls">
                  <a class="item-control" data-action="sanity-loss-type-delete" data-tooltip="CoC7.DeleteSanityLossEncounter"><i class="fa-solid fa-trash"></i></a>
                </div>
              </div>
            {{/unless}}
          {{/each}}
        </div>
      </section>
      <section class="bio-section">
        <header class="section-header">
          <h3 class="section-heading">{{localize 'CoC7.SanityLossImmunities'}}</h3>
          <div class="item-controls">
            <a class="item-control" data-action="sanity-loss-type-add" data-type="immunity" data-tooltip="CoC7.AddSanityLossImmunity"><i class="fa-regular fa-plus-circle"></i></a>
          </div>
        </header>
        <div class="events">
          {{#each document.system.sanityLossEvents as |sanityLossEvent index|}}
            {{#if sanityLossEvent.immunity}}
              <div class="event" data-index="{{index}}">
                <div class="title">{{sanityLossEvent.type}}</div>
                <div class="item-controls">
                  <a class="item-control" data-action="sanity-loss-type-delete" data-tooltip="CoC7.DeleteSanityLossImmunity"><i class="fa-solid fa-trash"></i></a>
                </div>
              </div>
            {{/if}}
          {{/each}}
        </div>
      </section>
      <section class="bio-section">
        <header class="section-header">
          <h3 class="section-heading">{{localize 'CoC7.BackgroundFlags'}}</h3>
        </header>
        <div class="events">
          <div class="event">
            <div class="title">{{localize 'CoC7.BackgroundFlagsMythosExperienced'}}</div>
            <div class="item-controls">
              <a class="item-control" data-tooltip="CoC7.BackgroundFlagsMythosExperienced" data-action="toggle-flag" data-toggle-flag="mythosInsanityExperienced">
                {{#if document.system.flags.mythosInsanityExperienced}}
                  <i class="fa-regular fa-check-square"></i>
                {{else}}
                  <i class="fa-regular fa-square"></i>
                {{/if}}
              </a>
            </div>
          </div>
          <div class="event">
            <div class="title">{{localize 'CoC7.BackgroundFlagsMythosHardened'}}</div>
            <div class="item-controls">
              <a class="item-control" data-tooltip="CoC7.BackgroundFlagsMythosHardened" data-action="toggle-flag" data-toggle-flag="mythosHardened">
                {{#if document.system.flags.mythosHardened}}
                  <i class="fa-regular fa-check-square"></i>
                {{else}}
                  <i class="fa-regular fa-square"></i>
                {{/if}}
              </a>
            </div>
          </div>
        </div>
      </section>
      <section class="bio-section">
        <header class="section-header">
          <h3 class="section-heading">{{localize 'CoC7.Books'}}</h3>
        </header>
        <div class="events">
          {{#each document.system.books as |book index|}}
            <div class="event" data-index="{{index}}">
              <div class="title">{{book.name}}</div>
              <div class=""><i class="fa-solid fa-check"></i></div>
              <div class="">{{localize 'CoC7.BookProgressSummary' fullStudies=book.fullStudies currentPercent=(percentValue book.progress book.necessary)}}</div>
              <div class="item-controls">
                <a class="item-control" data-action="bookClear" data-tooltip="CoC7.DeleteBookProgress"><i class="fa-solid fa-trash"></i></a>
              </div>
            </div>
          {{/each}}
        </div>
      </section>
    </div>

    <section class="bio-section">
      <header class="section-header">
        <h3 class="section-heading">{{localize 'CoC7.MonetaryTitle'}}</h3>
        {{#unless document.system.flags.locked}}
          <div class="item-controls">
            <a class="item-control" data-action="monetary-add"><i class="fa-regular fa-plus-circle"></i></a>
          </div>
        {{/unless}}
      </header>
      <div class="cash-assets">
        <div class="asset form-group">
          <label>{{localize 'CoC7.MonetaryFormatTitle'}}</label>
          <select name="system.monetary.format">
            {{selectOptions _monetaryFormats selected=document.system.monetary.format localize=true valueAttr='key' labelAttr='val'}}
          </select>
        </div>
        {{#if showCurrencySymbol}}
          <div class="asset form-group">
            <label>{{localize 'CoC7.MonetarySymbol'}}</label>
            <input type="text" name="system.monetary.symbol" value="{{document.system.monetary.symbol}}">
          </div>
        {{/if}}
        {{#each document.system.monetary.values as |value index|}}
          <div class="asset form-group" data-index="{{index}}">
            <input name="system.monetary.values.{{index}}.name" value="{{localize value.name}}" type="text" placeholder="{{localize 'CoC7.Name'}}">
            <input name="system.monetary.values.{{index}}.min" value="{{value.min}}" class="cash-assets-range" type="number" placeholder="{{localize 'CoC7.MonetaryCreditRatingMin'}}">
            <input name="system.monetary.values.{{index}}.max" value="{{value.max}}" class="cash-assets-range" type="number" placeholder="{{localize 'CoC7.MonetaryCreditRatingMax'}}" readonly="readonly">
            <select name="system.monetary.values.{{index}}.cashType" class="cash-assets-type">
              {{selectOptions ../_monetaryTypes selected=value.cashType localize=true valueAttr='key' labelAttr='val'}}
            </select>
            <input name="system.monetary.values.{{index}}.cashValue" value="{{value.cashValue}}" type="number" placeholder="{{localize 'CoC7.MonetaryValueCash'}}">
            <select name="system.monetary.values.{{index}}.assetsType" class="cash-assets-type">
              {{selectOptions ../_monetaryTypes selected=value.assetsType localize=true valueAttr='key' labelAttr='val'}}
            </select>
            <input name="system.monetary.values.{{index}}.assetsValue" value="{{value.assetsValue}}" type="number" placeholder="{{localize 'CoC7.MonetaryValueAssets'}}">
            <select name="system.monetary.values.{{index}}.spendingType" class="cash-assets-type">
              {{selectOptions ../_monetaryTypes selected=value.spendingType localize=true valueAttr='key' labelAttr='val'}}
            </select>
            <input name="system.monetary.values.{{index}}.spendingValue" value="{{value.spendingValue}}" type="number" placeholder="{{localize 'CoC7.MonetaryValueSpendingLevel'}}">
            {{#unless ../document.system.flags.locked}}
              <div class="item-controls">
                <a class="item-control" data-action="monetary-remove"><i class="fa-regular fa-minus-circle"></i></a>
              </div>
            {{/unless}}
          </div>
        {{/each}}
      </div>
    </section>
  {{/if}}
</section>