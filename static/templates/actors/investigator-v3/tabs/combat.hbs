<section class="tab combat scrollable {{tabs.combat.cssClass}}" data-group="primary" data-tab="combat">
  <header class="tab-header">
    <h2 class="tab-heading">{{localize 'CoC7.Combat'}}</h2>
  </header>
  <section class="weapon-list melee">
    <header class="section-header">
      <h3 class="section-heading">{{localize 'CoC7.MeleeWeapons'}}</h3>
      {{#unless document.system.flags.locked}}
        <div class="item-controls">
          <a class="item-control" data-action="item-add" data-type="weapon" data-tooltip="CoC7.AddWeapon" data-melee="true"><i class="fa-regular fa-plus-circle"></i></a>
        </div>
      {{/unless}}
    </header>
    <ul class="item-list">
      {{#each meleeWpn as |weapon|}}
        <li class="weapon-row item weapon{{#unless weapon.system.isSkillSet}} no-skill-set{{/unless}}" data-item-uuid="{{weapon.uuid}}"{{#unless weapon.system.isSkillSet}} data-tooltip="CoC7.NoSkill"{{/unless}}>
          <div class="expand-arrow clickable"><i class="fa-solid fa-play"></i></div>
          <div class="item-image" style="background-image: url('{{weapon.img}}')"></div>
          <div class="weapon-title">
            <div class="weapon-name combat{{#if weapon.system.isSkillSet}} rollable{{else}} item-edit{{/if}}">{{weapon.name}}</div>
            {{#if weapon.system.properties.thrown}}
              <a class="weapon-name combat alternative-skill{{#if weapon.system.isSkillSet}} rollable{{else}} item-edit{{/if}}" title="Throw"><i class="game-icon game-icon-thrown-knife"></i></a>
            {{/if}}
          </div>
          <div class="weapon-range">
            {{#each weapon.system.range as |range key|}}
              {{#if range.damage}}
                <div class="weapon-damage">
                  <a class="item-control" data-action="weapon-damage" data-range="{{key}}" data-tooltip="{{localize 'CoC7.RollDamageRange' range=range.value}}">{{range.damage}}</a>
                </div>
              {{/if}}
            {{/each}}
          </div>
          <div class="weapon-controls">
            {{#if weapon.system.properties.addb}}<span class="tag">{{localize 'CoC7.WeaponAddDb'}}</span>{{/if}}
            {{#if weapon.system.properties.ahdb}}<span class="tag">{{localize 'CoC7.WeaponAddHalfDb'}}</span>{{/if}}
          </div>
          <div class="item-controls">
            <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditWeapon"><i class="fa-solid fa-edit"></i></a>
            {{#unless ../document.system.flags.locked}}
              <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteWeapon"><i class="fa-solid fa-trash"></i></a>
            {{/unless}}
          </div>
        </li>
      {{/each}}
    </ul>
  </section>

  <section class="weapon-list range">
    <header class="section-header">
      <h3 class="section-heading">{{localize 'CoC7.RangeWeapons'}}</h3>
      {{#unless document.system.flags.locked}}
        <div class="item-controls">
          <a class="item-control" data-action="item-add" data-type="weapon" data-tooltip="CoC7.AddWeapon" data-rngd="true"><i class="fa-regular fa-plus-circle"></i></a>
        </div>
      {{/unless}}
    </header>
    <ul class="item-list">
      {{#each rangeWpn as |weapon|}}
        <li class="weapon-row item weapon{{#unless weapon.system.isSkillSet}} no-skill-set{{/unless}}" data-item-uuid="{{weapon.uuid}}"{{#unless weapon.system.isSkillSet}} data-tooltip="CoC7.NoSkill"{{/unless}}>
          <div class="expand-arrow clickable"><i class="fa-solid fa-play"></i></div>
          <div class="item-image" style="background-image: url('{{weapon.img}}')"></div>
          <div>
            <div class="weapon-name combat{{#if weapon.system.isSkillSet}} rollable{{else}} item-edit{{/if}}">{{weapon.name}}</div>
            {{#if weapon.usesAlternateSkill}}
              <a class="weapon-name combat alternative-skill{{#if weapon.system.isSkillSet}} rollable{{else}} item-edit{{/if}}" data-tooltip="CoC7.AutomaticFire"><i class="game-icon game-icon-machine-gun-magazine"></i></a>
            {{/if}}
          </div>
          <div class="weapon-range">
            {{#each weapon.system.range as |range key|}}
              {{#if range.damage}}
                <div class="weapon-damage">
                  <a class="item-control" data-action="weapon-damage" data-range="{{key}}" data-tooltip="{{localize 'CoC7.RollDamageRange' range=range.value}}">{{range.damage}}</a>
                </div>
              {{else}}
                <div></div>
              {{/if}}
            {{/each}}
          </div>
          <div class="weapon-controls">
            <div class="ammo">
              <span class="tag">{{weapon.system.ammo}}</span>
            </div>
            <div class="control">
              <a class="reload-weapon" data-tooltip="CoC7.Reload"><i class="game-icon game-icon-chaingun"></i></a>
            </div>
          </div>
          <div class="item-controls">
            <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditWeapon"><i class="fa-solid fa-edit"></i></a>
            {{#unless ../document.system.flags.locked}}
              <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteWeapon"><i class="fa-solid fa-trash"></i></a>
            {{/unless}}
          </div>
        </li>
      {{/each}}
    </ul>
  </section>

  <section class="weapon-list maneuver">{{!Ensure no white space so that CSS hides it}}</section>

  <section class="skill-list melee">
    <header class="section-header">
      <h3 class="section-heading">{{localize 'CoC7.MeleeSkills'}}</h3>
      {{#unless document.system.flags.locked}}
        <div class="item-controls">
          <a class="item-control" data-action="item-add" data-type="skill" title="{{localize 'CoC7.AddSkill'}}"><i class="fa-regular fa-plus-circle"></i></a>
        </div>
      {{/unless}}
    </header>
    <ul class="item-list skill melee">
      {{#each meleeSkills as |skill|}}
        <li class="item itemV2 skill" data-item-uuid="{{skill.uuid}}">
          <div class="item-image" style="background-image: url('{{skill.img}}')"></div>
          {{#if ../document.system.flags.locked}}
            <div class="item-name skill-name combat rollable" data-name-tooltip="{{skill.name}}" data-value-tooltip="{{skill.system.value}}">{{skill.name}}</div>
            <div class="item-score">{{skill.system.value}}</div>
            <div class="skill-icons">
              {{#unless skill.system.properties.noxpgain}}
                {{#if skill.system.flags.developement}}
                  <a class="item-control development-flag active" data-tooltip="{{localize 'CoC7.ToolTipSkillFlagToggle' status=(localize 'CoC7.ToolTipSkillFlagged')}}"><i class="fa-solid fa-circle-check"></i></a>
                {{else}}
                  <a class="item-control development-flag" data-tooltip="{{localize 'CoC7.ToolTipSkillFlagToggle' status=(localize 'CoC7.ToolTipSkillUnflagged')}}"><i class="fa-light fa-circle"></i></a>
                {{/if}}
              {{/unless}}
              <a class="item-control item-popup" data-tooltip="CoC7.SkillDetail"><i class="fa-solid fa-info-circle"></i></a>
            </div>
          {{else}}
            <div class="item-name">
              <input class="skill-name" type="text" value="{{skill.name}}">
            </div>
            <div class="item-score">
              <input class="npc-skill-score" type="text" value="{{skill.system.valueUnmodified}}">
            </div>
            <div class="item-controls">
              <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditSkill"><i class="fa-solid fa-edit"></i></a>
              <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteSkill"><i class="fa-solid fa-trash"></i></a>
            </div>
          {{/if}}
        </li>
      {{/each}}
    </ul>
  </section>

  <section class="skill-list range">
    <header class="section-header">
      <h3 class="section-heading">{{localize 'CoC7.RangeSkills'}}</h3>
      {{#unless document.system.flags.locked}}
        <div class="item-controls">
          <a class="item-control" data-action="item-add" data-type="skill" data-tooltip="CoC7.AddSkill"><i class="fa-regular fa-plus-circle"></i></a>
        </div>
      {{/unless}}
    </header>
    <ul class="item-list skill range">
      {{#each rangeSkills as |skill|}}
        <li class="item itemV2 skill" data-item-uuid="{{skill.uuid}}">
          <div class="item-image" style="background-image: url('{{skill.img}}')"></div>
          {{#if ../document.system.flags.locked}}
            <div class="item-name skill-name combat rollable" data-name-tooltip="{{skill.name}}" data-value-tooltip="{{skill.system.value}}">{{skill.name}}</div>
            <div class="item-score">{{skill.system.value}}</div>
            <div class="skill-icons">
              {{#unless skill.system.properties.noxpgain}}
                {{#if skill.system.flags.developement}}
                  <a class="item-control development-flag active" data-tooltip="{{localize 'CoC7.ToolTipSkillFlagToggle' status=(localize 'CoC7.ToolTipSkillFlagged')}}"><i class="fa-solid fa-circle-check"></i></a>
                {{else}}
                  <a class="item-control development-flag" data-tooltip="{{localize 'CoC7.ToolTipSkillFlagToggle' status=(localize 'CoC7.ToolTipSkillUnflagged')}}"><i class="fa-light fa-circle"></i></a>
                {{/if}}
              {{/unless}}
              <a class="item-control item-popup" data-tooltip="CoC7.SkillDetail"><i class="fa-solid fa-info-circle"></i></a>
            </div>
          {{else}}
            <div class="item-name">
              <input class="skill-name" type="text" value="{{skill.name}}">
            </div>
            <div class="item-score">
              <input class="npc-skill-score" type="text" value="{{skill.system.valueUnmodified}}">
            </div>
            <div class="item-controls">
              <a class="item-control" data-action="item-edit" data-tooltip="CoC7.EditSkill"><i class="fa-solid fa-edit"></i></a>
              <a class="item-control" data-action="item-delete" data-tooltip="CoC7.DeleteSkill"><i class="fa-solid fa-trash"></i></a>
            </div>
          {{/if}}
        </li>
      {{/each}}
    </ul>
  </section>
</section>